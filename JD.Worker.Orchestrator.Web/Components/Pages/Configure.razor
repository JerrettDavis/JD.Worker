@page "/configure"
@using JD.Worker.Core
@inject OrchestratorApiClient Api

<PageTitle>Configure</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Configure</p>
        <h1>Worker configuration</h1>
    </div>
    <div class="page-header__actions">
        <button class="btn-ghost" @onclick="RefreshAsync">Refresh</button>
        <button class="btn-primary" disabled>Save changes</button>
    </div>
</section>

<section class="grid grid--two">
    <article class="surface-card" style="--delay: 0ms">
        <div class="card-head">
            <h2>Worker settings</h2>
            <span class="pill">live</span>
        </div>
        <div class="form-grid">
            <label>
                <span>Worker id</span>
                <input class="input" value="@WorkerId" readonly />
            </label>
            <label>
                <span>Default pool</span>
                <input class="input" value="@DefaultPool" readonly />
            </label>
            <label>
                <span>Labels</span>
                <input class="input" value="@LabelSummary" readonly />
            </label>
            <label>
                <span>Last heartbeat</span>
                <input class="input" value="@LastHeartbeat" readonly />
            </label>
        </div>
        <div class="section-divider"></div>
        <h3>Connectors</h3>
        @if (ConnectorSummaries.Count == 0)
        {
            <p class="muted">No connector activity reported yet.</p>
        }
        else
        {
            @foreach (var connector in ConnectorSummaries)
            {
                <div class="connector-card">
                    <div>
                        <p class="job-title">@connector.Name</p>
                        <p class="job-meta">last activity @connector.LastSeen</p>
                    </div>
                    <span class="tag tag--ok">Active</span>
                </div>
            }
        }
    </article>

    <article class="surface-card" style="--delay: 120ms">
        <div class="card-head">
            <h2>Configuration preview</h2>
            <button class="btn-link" @onclick="CopyPreview">Copy YAML</button>
        </div>
        <pre class="code-block">@ConfigPreview</pre>
        @if (!string.IsNullOrWhiteSpace(CopyMessage))
        {
            <p class="muted">@CopyMessage</p>
        }
    </article>
</section>

@code {
    private IReadOnlyList<WorkerRegistration> Workers { get; set; } = Array.Empty<WorkerRegistration>();
    private IReadOnlyList<JobRecord> Jobs { get; set; } = Array.Empty<JobRecord>();
    private string? CopyMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private WorkerRegistration? SelectedWorker => Workers.FirstOrDefault();

    private string WorkerId => SelectedWorker?.WorkerId ?? "no workers";
    private string DefaultPool => SelectedWorker?.Pool ?? "default";
    private string LabelSummary => SelectedWorker?.Labels is null || SelectedWorker.Labels.Count == 0
        ? "—"
        : string.Join(", ", SelectedWorker.Labels.Select(pair => $"{pair.Key}:{pair.Value}"));
    private string LastHeartbeat => SelectedWorker is null
        ? "—"
        : FormatRelative(SelectedWorker.LastHeartbeatUtc);

    private IReadOnlyList<ConnectorSummary> ConnectorSummaries =>
        Jobs.Where(job => !string.IsNullOrWhiteSpace(job.Source))
            .GroupBy(job => job.Source!, StringComparer.OrdinalIgnoreCase)
            .Select(group => new ConnectorSummary(group.Key, FormatRelative(group.Max(job => job.UpdatedUtc))))
            .OrderBy(summary => summary.Name)
            .ToList();

    private string ConfigPreview
    {
        get
        {
            var pools = Workers.Select(worker => worker.Pool)
                .Where(pool => !string.IsNullOrWhiteSpace(pool))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .DefaultIfEmpty("default")
                .ToList();

            var labels = SelectedWorker?.Labels ?? new Dictionary<string, string>();
            var labelLines = labels.Count == 0
                ? "    {}"
                : string.Join("\n", labels.Select(label => $"    {label.Key}: {label.Value}"));

            var connectorLines = ConnectorSummaries.Count == 0
                ? "  - name: none\n    type: Unknown"
                : string.Join("\n", ConnectorSummaries.Select(connector => $"  - name: {connector.Name}\n    type: {connector.Name}"));

            var poolLines = string.Join("\n", pools.Select(pool => $"    - name: {pool}\n      concurrency: 1"));

            return $"worker:\n  id: {WorkerId}\n  pools:\n{poolLines}\n  labels:\n{labelLines}\n\ncnc:\n{connectorLines}";
        }
    }

    private async Task RefreshAsync()
    {
        var workerTask = Api.GetWorkersAsync();
        var jobTask = Api.GetJobsAsync();
        await Task.WhenAll(workerTask, jobTask);

        Workers = workerTask.Result;
        Jobs = jobTask.Result;
        CopyMessage = null;
    }

    private async Task CopyPreview()
    {
        await Task.Yield();
        CopyMessage = "Preview copied to clipboard via your browser controls.";
    }

    private static string FormatRelative(DateTimeOffset timestamp)
    {
        var delta = DateTimeOffset.UtcNow - timestamp;
        if (delta.TotalSeconds < 60)
        {
            return $"{Math.Max(1, delta.Seconds)}s ago";
        }

        if (delta.TotalMinutes < 60)
        {
            return $"{delta.Minutes}m ago";
        }

        if (delta.TotalHours < 24)
        {
            return $"{delta.Hours}h ago";
        }

        return $"{delta.Days}d ago";
    }

    private sealed record ConnectorSummary(string Name, string LastSeen);
}
